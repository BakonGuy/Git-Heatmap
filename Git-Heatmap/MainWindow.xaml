<Window x:Class="Git_Heatmap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Git Heatmap" Height="620" Width="980" MinHeight="500" MinWidth="820">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Refresh" Width="90" Margin="0,0,8,0" Click="RefreshButton_OnClick" />
            <Button Content="Config" Width="90" Margin="0,0,8,0" Click="ConfigButton_OnClick" />
            <Button Content="Export HTML" Width="100" Margin="0,0,8,0" Click="ExportHtmlButton_OnClick" />
            <Button Content="Export PNG" Width="100" Click="ExportPngButton_OnClick" />
        </StackPanel>

        <Border x:Name="HeatmapPanel" Background="#0D1117" CornerRadius="8" Padding="16" BorderBrush="#30363D" BorderThickness="1">
            <DockPanel>
                <TextBlock x:Name="SummaryText" DockPanel.Dock="Top" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#E6EDF3" />
                <TextBlock x:Name="StatusText" DockPanel.Dock="Bottom" Margin="0,12,0,0" Foreground="#8B949E" TextWrapping="Wrap" />

                <StackPanel>
                    <UniformGrid x:Name="HeatmapGrid" Rows="7" Columns="53" HorizontalAlignment="Left" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <TextBlock Foreground="#8B949E" Margin="0,0,8,0" Text="Less" />
                        <Border Width="12" Height="12" Margin="0,0,4,0" Background="#161B22" CornerRadius="2" />
                        <Border Width="12" Height="12" Margin="0,0,4,0" Background="#0E4429" CornerRadius="2" />
                        <Border Width="12" Height="12" Margin="0,0,4,0" Background="#006D32" CornerRadius="2" />
                        <Border Width="12" Height="12" Margin="0,0,4,0" Background="#26A641" CornerRadius="2" />
                        <Border Width="12" Height="12" Margin="0,0,8,0" Background="#39D353" CornerRadius="2" />
                        <TextBlock Foreground="#8B949E" Text="More" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
    </DockPanel>
</Window>