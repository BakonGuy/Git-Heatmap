<Window x:Class="Git_Heatmap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Git Heatmap" Height="620" Width="980" MinHeight="500" MinWidth="820">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Refresh" Width="90" Margin="0,0,8,0" Click="RefreshButton_OnClick" />
            <Button Content="Config" Width="90" Margin="0,0,8,0" Click="ConfigButton_OnClick" />
            <Button Content="Export HTML" Width="120" Margin="0,0,8,0" Click="ExportHtmlButton_OnClick" />
            <Button Content="Export PNG" Width="120" Click="ExportPngButton_OnClick" />
        </StackPanel>

        <TextBlock x:Name="StatusText" DockPanel.Dock="Bottom" Margin="0,12,0,0" Foreground="#9A9A9A" TextWrapping="Wrap" />

        <Border x:Name="HeatmapPanel" Background="#111111" CornerRadius="8" Padding="16" BorderBrush="#2F2F2F" BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Top">
            <DockPanel>
                <TextBlock x:Name="SummaryText" DockPanel.Dock="Top" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#E6E6E6" />

                <StackPanel>
                    <Grid x:Name="HeatmapGrid" HorizontalAlignment="Left" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <TextBlock Foreground="#9A9A9A" Margin="0,0,8,0" Text="Less" />
                        <Border Width="12" Height="12" Margin="0,0,4,0" Background="#161B22" CornerRadius="2" />
                        <Border Width="12" Height="12" Margin="0,0,4,0" Background="#4A2A0A" CornerRadius="2" />
                        <Border Width="12" Height="12" Margin="0,0,4,0" Background="#7A3E0B" CornerRadius="2" />
                        <Border Width="12" Height="12" Margin="0,0,4,0" Background="#B45309" CornerRadius="2" />
                        <Border Width="12" Height="12" Margin="0,0,8,0" Background="#F97316" CornerRadius="2" />
                        <TextBlock Foreground="#9A9A9A" Text="More" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
    </DockPanel>
</Window>
