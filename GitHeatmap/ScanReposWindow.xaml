<Window x:Class="Git_Heatmap.ScanReposWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Scan for Repos"
        Width="760"
        Height="640"
        MinWidth="620"
        MinHeight="500"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="14">
        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="AddToConfigButton" Grid.Column="1" Width="120" Content="Add to Config" IsEnabled="False" Click="AddToConfigButton_OnClick" />
        </Grid>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Root Path" />
                <Grid Margin="0,4,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PathTextBox" Grid.Column="0" TextChanged="PathTextBox_OnTextChanged" />
                    <Button Grid.Column="2" Width="80" Content="Browse..." Click="BrowseButton_OnClick" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="1">
                <Button x:Name="ScanButton" Width="80" Content="Scan" IsEnabled="False" HorizontalAlignment="Left" Click="ScanButton_OnClick" />
                <CheckBox x:Name="IncludeSubmodulesCheckBox" Margin="0,8,0,0" Content="Include submodules" />
            </StackPanel>

            <TextBlock Grid.Row="2" x:Name="StatusText" Margin="0,10,0,10" TextWrapping="Wrap" />

            <Border Grid.Row="3" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ResultsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Margin="0,4,0,4"
                                          Content="{Binding DisplayText}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Checked="RepoCheckBox_OnCheckedChanged"
                                          Unchecked="RepoCheckBox_OnCheckedChanged"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
